+function gatherQuestionVariants(question: string): string[] {
+  const base = question.trim();
+  if (base.length === 0) return [question];
+  const candidates = new Set<string>([base]);
+  const withoutPrefix = base
+    .replace(/^(请|麻烦)?(说明|解释|介绍|查询|检索|回答|帮我查一下|帮我查询)\s*/u, '')
+    .trim();
+  if (withoutPrefix && withoutPrefix !== base) candidates.add(withoutPrefix);
+  const titleLike = withoutPrefix
+    .replace(/[？?。.!！\s]+$/u, '')
+    .replace(/^(什么是|何为)\s*/u, '')
+    .replace(/\s*(是什么|是什麼|什么意思|是啥|如何操作|怎么做|怎麼做|有哪些要求|有什么要求)$/u, '')
+    .trim();
+  if (titleLike && titleLike !== base && titleLike.length >= 2) {
+    candidates.add(titleLike);
+  }
+  return Array.from(candidates).slice(0, MAX_GATHER_QUERY_VARIANTS);
+}
