+function buildChatToolsForAiSdk(toolDefs: ChatToolDef[] | undefined): Record<string, any> {
+  return (toolDefs ?? []).reduce((acc, t) => {
+    acc[t.name] = {
+      description: t.description,
+      inputSchema: jsonSchema(t.inputSchema as any) as any,
+    };
+    return acc;
+  }, {} as Record<string, any>);
+}
+
+/**
+ * @internal exported for tests; not part of the public gateway API.
+ */
+export function __buildChatToolsForTests(toolDefs: ChatToolDef[] | undefined): Record<string, any> {
+  return buildChatToolsForAiSdk(toolDefs);
+}
+
+function isAiSdkToolResultOutput(value: unknown): boolean {
+  if (!value || typeof value !== 'object') return false;
+  const type = (value as { type?: unknown }).type;
+  return type === 'text' ||
+    type === 'json' ||
+    type === 'execution-denied' ||
+    type === 'error-text' ||
+    type === 'error-json' ||
+    type === 'content';
+}
+
+function toJsonValue(value: unknown): any {
+  if (value === undefined) return null;
+  try {
+    return JSON.parse(JSON.stringify(value));
+  } catch {
+    return String(value);
+  }
+}
+
+function toAiSdkToolResultOutput(output: unknown, isError?: boolean): any {
+  if (isAiSdkToolResultOutput(output)) return output;
+  if (isError) {
+    return typeof output === 'string'
+      ? { type: 'error-text', value: output }
+      : { type: 'error-json', value: toJsonValue(output) };
+  }
+  return typeof output === 'string'
+    ? { type: 'text', value: output }
+    : { type: 'json', value: toJsonValue(output) };
+}
+
+function toAiSdkToolResultPart(block: Extract<ChatBlock, { type: 'tool-result' }>): any {
+  return {
+    type: 'tool-result',
+    toolCallId: block.toolCallId,
+    toolName: block.toolName,
+    output: toAiSdkToolResultOutput(block.output, block.isError),
+  };
+}
+
+function buildModelMessagesForAiSdk(messages: ChatMessage[]): any[] {
+  return messages.map(message => {
+    if (!Array.isArray(message.content)) return message;
+
+    const blocks = message.content;
+    const toolResults = blocks.filter(
+      (block): block is Extract<ChatBlock, { type: 'tool-result' }> => block.type === 'tool-result',
+    );
+
+    if (message.role === 'tool' || (toolResults.length > 0 && toolResults.length === blocks.length)) {
+      return {
+        role: 'tool',
+        content: toolResults.map(toAiSdkToolResultPart),
+      };
+    }
+
+    if (message.role === 'assistant') {
+      return {
+        role: 'assistant',
+        content: blocks.map(block =>
+          block.type === 'tool-result'
+            ? toAiSdkToolResultPart(block)
+            : block,
+        ),
+      };
+    }
+
+    if (message.role === 'system') {
+      return {
+        role: 'system',
+        content: blocks
+          .filter((block): block is Extract<ChatBlock, { type: 'text' }> => block.type === 'text')
+          .map(block => block.text)
+          .join('\n'),
+      };
+    }
+
+    return {
+      role: 'user',
+      content: blocks
+        .filter((block): block is Extract<ChatBlock, { type: 'text' }> => block.type === 'text')
+        .map(block => ({ type: 'text', text: block.text })),
+    };
+  });
+}
+
+/**
+ * @internal exported for tests; not part of the public gateway API.
+ */
+export function __buildModelMessagesForTests(messages: ChatMessage[]): any[] {
+  return buildModelMessagesForAiSdk(messages);
+}
