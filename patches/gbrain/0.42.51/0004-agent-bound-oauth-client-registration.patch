+  private normalizeAgentClientBindings(bindings?: AgentClientBindings): AgentClientBindings | undefined {
+    if (!bindings) return undefined;
+    const boundTools = (bindings.boundTools || []).map(s => String(s).trim()).filter(Boolean);
+    if (boundTools.length === 0) {
+      throw new Error('Agent client bindings require at least one bound tool.');
+    }
+    const boundSlugPrefixes = (bindings.boundSlugPrefixes || []).map(s => String(s).trim()).filter(Boolean);
+    const boundMaxConcurrent = bindings.boundMaxConcurrent === undefined
+      ? 1
+      : Number(bindings.boundMaxConcurrent);
+    if (!Number.isInteger(boundMaxConcurrent) || boundMaxConcurrent < 1) {
+      throw new Error('boundMaxConcurrent must be a positive integer.');
+    }
+    const budgetUsdPerDay = bindings.budgetUsdPerDay === undefined
+      ? undefined
+      : Number(bindings.budgetUsdPerDay);
+    if (budgetUsdPerDay !== undefined && (!Number.isFinite(budgetUsdPerDay) || budgetUsdPerDay < 0)) {
+      throw new Error('budgetUsdPerDay must be a non-negative number.');
+    }
+    return {
+      boundTools,
+      boundSourceId: bindings.boundSourceId ? String(bindings.boundSourceId).trim() : undefined,
+      boundBrainId: bindings.boundBrainId ? String(bindings.boundBrainId).trim() : undefined,
+      boundSlugPrefixes,
+      boundMaxConcurrent,
+      budgetUsdPerDay,
+    };
+  }
+
