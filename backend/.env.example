# Project_R Backend Environment Variables
# Copy this file to .env and fill in real values

# === Application ===
APP_SECRET_KEY=                           # JWT 签名密钥（生产环境用长随机字符串）
JWT_EXPIRY_HOURS=24                       # JWT Token 有效期（小时）
CORS_ORIGINS=["*"]                        # 允许的前端来源（生产环境改为具体地址）
LOG_LEVEL=INFO                            # 日志级别：DEBUG / INFO / WARNING / ERROR

# === Database ===
DATABASE_URL=sqlite:///./app.db           # 数据库文件路径（SQLite）

# === LLM Provider / Model Profiles ===
# LLM_DEFAULT_PROFILE 是前端默认选中的模型配置档。
# 同一 Provider 的多个 profile 会共用同一组 API Key，例如 DeepSeek Flash / Pro 共用 DEEPSEEK_API_KEYS。
LLM_DEFAULT_PROFILE=deepseek-flash
LLM_MODEL_PROFILES=deepseek-flash,deepseek-pro,mimo-v2-5,mimo-v2-5-pro

# 兼容旧配置入口：未选择 profile 时使用该 Provider。
LLM_PROVIDER=deepseek
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60
# DeepSeek 思考强度：high / max。low / medium 会按兼容规则映射为 high。
LLM_REASONING_EFFORT=high
LLM_SYSTEM_PROMPT=你是 Project_R 的企业知识与业务流程助手。回答要准确、简洁，并优先说明可执行下一步。

LLM_PROFILE_DEEPSEEK_FLASH_LABEL=DeepSeek Flash
LLM_PROFILE_DEEPSEEK_FLASH_DESCRIPTION=文本对话、快速推理
LLM_PROFILE_DEEPSEEK_FLASH_PROVIDER=deepseek
LLM_PROFILE_DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
LLM_PROFILE_DEEPSEEK_FLASH_REASONING_EFFORT=high

LLM_PROFILE_DEEPSEEK_PRO_LABEL=DeepSeek Pro
LLM_PROFILE_DEEPSEEK_PRO_DESCRIPTION=文本对话、复杂推理
LLM_PROFILE_DEEPSEEK_PRO_PROVIDER=deepseek
LLM_PROFILE_DEEPSEEK_PRO_MODEL=deepseek-v4-pro
LLM_PROFILE_DEEPSEEK_PRO_REASONING_EFFORT=max

LLM_PROFILE_MIMO_V2_5_LABEL=MiMo V2.5
LLM_PROFILE_MIMO_V2_5_DESCRIPTION=文本/图像/视频/音频理解
LLM_PROFILE_MIMO_V2_5_PROVIDER=mimo
LLM_PROFILE_MIMO_V2_5_MODEL=mimo-v2.5
LLM_PROFILE_MIMO_V2_5_SUPPORTS_VISION=true

LLM_PROFILE_MIMO_V2_5_PRO_LABEL=MiMo V2.5 Pro
LLM_PROFILE_MIMO_V2_5_PRO_DESCRIPTION=文本理解、复杂推理
LLM_PROFILE_MIMO_V2_5_PRO_PROVIDER=mimo
LLM_PROFILE_MIMO_V2_5_PRO_MODEL=mimo-v2.5-pro
LLM_PROFILE_MIMO_V2_5_PRO_SUPPORTS_VISION=false

# === Claude API Keys（多 Key 轮询）===
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_API_VERSION=2023-06-01
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_KEYS=                         # 可选：逗号分隔，优先参与轮询
CLAUDE_API_KEY_1=                         # sk-ant-...
# CLAUDE_API_KEY_2=                       # sk-ant-...

# === OpenAI / ChatGPT API Keys（OpenAI Chat Completions 适配）===
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEYS=
# OPENAI_API_KEY_1=
# OPENAI_API_KEY_2=

# === DeepSeek API Keys（OpenAI-compatible 适配）===
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEYS=
# DEEPSEEK_API_KEY_1=
# DEEPSEEK_API_KEY_2=

# === MiMo API Keys（OpenAI-compatible 适配）===
MIMO_MODEL=mimo-v2.5
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEYS=
# MIMO_API_KEY_1=
# MIMO_API_KEY_2=

# === GBrain — 知识库内核 ===
GBRAIN_ENABLED=true
GBRAIN_BASE_URL=http://127.0.0.1:3131       # gbrain serve --http --port 3131
GBRAIN_TIMEOUT_SECONDS=5
GBRAIN_SERVICE_BEARER_TOKEN=                # Project_R 后端 service account token，不返回前端
GBRAIN_HOME=./workspace_data/_gbrain  # GBrain 会在该目录下使用 .gbrain/ 保存配置和 PGLite
GBRAIN_CLI_WORKDIR=../reference/gbrain-master     # 相对 backend/ 的 GBrain 源码路径
GBRAIN_BUN_BIN=bun                                # 本机 Bun 可执行文件
GBRAIN_HTTP_BIND=127.0.0.1
GBRAIN_COMPANY_SOURCE_ID=company-wiki
GBRAIN_COMPANY_SOURCE_NAME=Project_R Company Wiki
GBRAIN_COMPANY_RAW_PATH=./workspace_data/global/company-wiki/raw
GBRAIN_COMPANY_DERIVED_PATH=./workspace_data/_preprocessed/company/company-wiki/gbrain-ready
GBRAIN_COMPANY_MANIFESTS_PATH=./workspace_data/_gbrain/manifests
GBRAIN_LOCAL_GIT_ENABLED=true               # derived/ 本地 Git，仅用于审计、diff、回滚
GBRAIN_COMPANY_QUERY_EXPANSION_ENABLED=true # 中文 /query 同时跑受控英文业务检索词，提高中英双语知识命中
GBRAIN_THINK_ENABLED=false                  # true 后允许 /query --think 或 /think 走 GBrain think
GBRAIN_THINK_SOURCE_SCOPE_VERIFIED=false    # 上游 think 检索链路确认完整 source scope 后才可设为 true
GBRAIN_THINK_ALLOWED_SOURCES=company-wiki   # 允许该 OAuth client 读取的 source 列表，项目源需显式加入
GBRAIN_THINK_OAUTH_CLIENT_ID=               # 使用 gbrain auth register-client 创建的 source-scoped OAuth client
GBRAIN_THINK_OAUTH_CLIENT_SECRET=           # 只放后端 .env，不返回前端
GBRAIN_THINK_OAUTH_SCOPE=read write
GBRAIN_THINK_OAUTH_TOKEN_AUTH_METHOD=client_secret_post
GBRAIN_THINK_MODEL=deepseek:deepseek-chat
GBRAIN_THINK_ROUNDS=1
GBRAIN_THINK_TIMEOUT_SECONDS=90             # think 综合回答可能慢于普通 query/status
# 示例：gbrain auth register-client project-r-company-think --grant-types client_credentials --scopes "read write" --source company-wiki --federated-read company-wiki
GBRAIN_AGENT_ENABLED=false                  # true 后允许管理员提交 GBrain agent / citation-fixer 任务
GBRAIN_AGENT_OAUTH_CLIENT_ID=               # GBrain 侧带 agent scope 的 OAuth client；必须绑定工具/source/slug 前缀/预算
GBRAIN_AGENT_OAUTH_CLIENT_SECRET=           # 只放后端 .env，不返回前端
GBRAIN_AGENT_OAUTH_SCOPE=agent
GBRAIN_AGENT_OAUTH_TOKEN_AUTH_METHOD=client_secret_post
GBRAIN_AGENT_MODEL=deepseek:deepseek-chat   # 非 Anthropic 模型需要 GBrain agent.use_gateway_loop=true
GBRAIN_AGENT_GATEWAY_LOOP_VERIFIED=false    # 执行 gbrain config set agent.use_gateway_loop true 并确认后再设 true
GBRAIN_AGENT_BINDING_SUBMIT_VERIFIED=false  # Project_R 通过 submit_agent 冒烟验证 OAuth 工具/source/slug/budget 绑定后才设 true
GBRAIN_AGENT_INLINE_EXECUTION_VERIFIED=false # PGLite 下用 jobs submit subagent --follow 跑通只读 subagent 后才设 true
GBRAIN_AGENT_EXECUTION_VERIFIED=false       # 真实跑通过 citation-fixer/subagent 后才可设 true，管理员状态才显示 ready
GBRAIN_AGENT_TIMEOUT_SECONDS=120
GBRAIN_CITATION_FIXER_TOOLS=search,get_page,put_page,list_pages
GBRAIN_EMBEDDING_MODEL=ollama:mxbai-embed-large # 本地免费 GBrain embedding provider
GBRAIN_EMBEDDING_DIMENSIONS=1024                # mxbai-embed-large 原生维度
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1       # Ollama OpenAI-compatible embedding endpoint
ZEROENTROPY_API_KEY=                            # 可选：未来切回 ZeroEntropy 托管 embedding 时使用
GBRAIN_PDF_STRUCTURED_EXTRACTION_ENABLED=false  # true 时 PDF 走模型辅助结构化提炼，不走纯文本直入库
GBRAIN_PDF_EXTRACTOR_MODEL_PROFILE=mimo-v2-5
GBRAIN_PDF_EXTRACTOR_BATCH_MAX_CHARS=28000  # 每批送入模型的 PDF 中间文本上限
GBRAIN_PDF_EXTRACTOR_MAX_PAGES=0            # 0 表示分析全部可抽取文本页；调小可做快速试跑
GBRAIN_PDF_EXTRACTOR_VISION_PAGES=auto      # auto 自动选封面/目录/分布页/表格页；也可手写 1,3,5
GBRAIN_PDF_EXTRACTOR_MAX_VISION_PAGES=8     # 视觉页上限；越高越贵
# PDF 提炼输出固定执行 language_policy=bilingual_zh_en_aligned；不提供关闭开关。
GBRAIN_PROJECT_PDF_STRUCTURED_EXTRACTION_ENABLED=true # 项目一键录入中复杂 PDF/图纸默认调用 MiMo 结构化提炼
GBRAIN_PROJECT_MEDIA_TRANSCRIPTION_ENABLED=true       # 项目一键录入中无 transcript 的音视频默认尝试 MiMo 自动转写
GBRAIN_PROJECT_EMAIL_EXTRACTION_ENABLED=true          # 项目一键录入中 EML 默认提炼成项目邮件 Markdown
GBRAIN_PROJECT_IMAGE_EXTRACTION_ENABLED=true          # 项目一键录入中图片/截图默认调用 MiMo 视觉提炼
GBRAIN_EMAIL_ATTACHMENT_RECURSION_ENABLED=true        # EML 附件抽出后重新走项目分类/提炼流程
GBRAIN_MEDIA_TRANSCRIPTION_MODEL_PROFILE=mimo-v2-5
GBRAIN_MEDIA_TRANSCRIPTION_MAX_RAW_BYTES=37000000     # base64 后需低于 MiMo 50MB 上限，37MB raw 约等于 49MB base64
GBRAIN_MEDIA_TRANSCRIPTION_VIDEO_FPS=0.2              # 会议转写默认低帧率，控制视频视觉 token
GBRAIN_MEDIA_TRANSCRIPTION_VIDEO_RESOLUTION=default
GBRAIN_MEDIA_TRANSCRIPTION_VIDEO_MODE=audio_first     # MP4/MOV 默认先抽音频再转写，比直接视频输入更稳、更省 token
GBRAIN_MEDIA_TRANSCRIPTION_AUDIO_BITRATE=64k
GBRAIN_MEDIA_TRANSCRIPTION_SEGMENT_SECONDS=300        # 视频音轨默认按 5 分钟切段，避免长会议被模型输出上限截断
GBRAIN_MEDIA_TRANSCRIPTION_FFMPEG_TIMEOUT_SECONDS=900
GBRAIN_TRANSCRIPT_REFINEMENT_ENABLED=true             # 转写后做说话人标签统一和术语纠错
GBRAIN_TRANSCRIPT_REFINEMENT_MODEL_PROFILE=deepseek-flash
GBRAIN_TRANSCRIPT_TERMINOLOGY=Project_R,GBrain,MiMo,DeepSeek,Ollama,mxbai-embed-large,BFI,AURA,SPECWISE,SYNOVA,Obsidian,LlamaIndex,Proma,Agent,Skill,RAG,VMU,AS 1288,AS 2047,NAD,Nicholas,Gary,项目组,设计组,业务数字化
PROJECT_R_FFMPEG_BIN=                                 # 可选；为空时优先使用 imageio-ffmpeg bundled binary，其次查找系统 ffmpeg
GBRAIN_EMAIL_EXTRACTOR_MODEL_PROFILE=deepseek-flash
GBRAIN_EMAIL_EXTRACTOR_LLM_ENABLED=true
GBRAIN_EMAIL_EXTRACTOR_MAX_BODY_CHARS=24000
GBRAIN_IMAGE_EXTRACTOR_MODEL_PROFILE=mimo-v2-5
GBRAIN_IMAGE_EXTRACTOR_MAX_RAW_BYTES=10000000

# === Paths（默认相对路径，迁移到时按需调整）===
GENERATED_FILES_PATH=./generated_files    # 临时生成文件目录
UPDATE_PACKAGES_PATH=./update_packages    # 内网客户端安装包目录
TEMPLATES_PATH=./templates                # 文件模板目录
LOGS_PATH=./logs                          # 日志文件目录
WORKSPACE_MAX_UPLOAD_MB=100               # 普通成员单文件上传上限（MB）
WORKSPACE_ADMIN_MAX_UPLOAD_MB=1024        # 管理员/项目管理员单文件上传上限（MB）

# === Cleanup ===
GENERATED_FILES_TTL_HOURS=48              # 生成文件保留时间（小时）
